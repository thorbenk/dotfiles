{
  "agent_buffer_font_size": 14.0,
  "soft_wrap": "prefer_line",
  "ssh_connections": [],
  "diff_view_style": "split",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "default_config_options": {
        "mode": "https://agentclientprotocol.com/protocol/session-modes#autopilot",
        "model": "gpt-5.5",
      },
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "bypassPermissions",
      },
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"],
      },
      "type": "registry",
    },
  },
  "which_key": { "enabled": true },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "file_types": {
    "C++": ["i"],
    "Dockerfile": ["Dockerfile"],
  },
  "use_system_path_prompts": false,
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "show_turn_stats": true,
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.5",
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-haiku-4.5",
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2-codex",
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.1-codex-max",
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3-pro-preview",
      },
    ],
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gpt-5.5",
    },
    "model_parameters": [],
  },
  "pane_split_direction_vertical": "right",
  "pane_split_direction_horizontal": "down",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  // "server_url": "https://127.0.0.1:389",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },
  "relative_line_numbers": "disabled",
  "cursor_blink": false,
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "file_scan_exclusions": [
    "**/*.min.js",
    "__pycache__",
    ".git",
    ".venv",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
  ],
  "ui_font_family": "Roboto", // Alternatives: "Lato"
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "agent_ui_font_size": 14.0,
  "buffer_font_family": "FiraCode Nerd Font",
  "tabs": {
    "file_icons": true,
    "git_status": false,
  },
  "autosave": "on_focus_change",
  "use_autoclose": false,
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "!pyright"],
    },
    "Markdown": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
    "YAML": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
    "JSON": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
    "TOML": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        "path": "~/.local/bin/clangd",
      },
    },
    "basedpyright": {
      "settings": {
        "basedpyright.disableOrganizeImports": true,
        "basedpyright.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "standard",
        },
        "python": {
          "pythonPath": ".venv/bin/python",
        },
      },
    },
  },
  "journal": {
    "hour_format": "hour24",
  },
  "preview_tabs": {
    "enabled": true,
  },
  "search": {
    "case_sensitive": false,
    "regex": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
    "copy_on_select": true,
    "line_height": "standard",
    "detect_venv": "off",
    "shell": "system",
    "env": {
      "EDITOR": "zed --wait",
      "TERM": "xterm-256color",
    },
  },
  "file_finder": {
    "file_icons": true,
    "modal_max_width": "large",
  },
  // "unstable.ui_density": "compact",
  "git_panel": {
    // Whether to show the git panel button in the status bar.
    "tree_view": true,
    "button": true,
    // Where to the git panel. Can be 'left' or 'right'.
    "dock": "left",
    // Default width of the git panel.
    "default_width": 360,
    // Style of the git status indicator in the panel.
    //
    // Default: icon
    "status_style": "icon",
    "scrollbar": {
      // When to show the scrollbar in the git panel.
      //
      // Default: inherits editor scrollbar settings
      "show": null,
    },
    "collapse_untracked_diff": true,
  },
}
